generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  password        String
  role            Role      @default(ANALYST)
  isActive        Boolean   @default(true)
  cargo           String?
  projects        Project[]     @relation("ProjectOwner")
  managedProjects Project[]     @relation("ProjectToGestor")
  tasks           Task[]
  assignedTasks       Task[]        @relation("TaskAssignees")
  comments            TaskComment[]
  responsibleProjects Project[]     @relation("ProjectResponsibles")
  gestorId        String?
  gestor          User?         @relation("UserToGestor", fields: [gestorId], references: [id])
  subordinates    User[]        @relation("UserToGestor")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?
  passwordNeedsReset  Boolean   @default(false)
  auditLogs           AuditLog[]
}

enum Role {
  SUPER_ADMIN
  MANAGER
  ANALYST
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String?
  ownerId     String
  owner       User     @relation("ProjectOwner", fields: [ownerId], references: [id])
  tasks       Task[]
  gestorId     String?
  gestor       User?         @relation("ProjectToGestor", fields: [gestorId], references: [id])
  responsibles User[]        @relation("ProjectResponsibles")
  subChapters  SubChapter[]
  
  // Temporal control fields
  dataInicio  DateTime?
  dataFim     DateTime?
  
  // Classification
  categoria   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id         String     @id @default(uuid())
  title      String
  status     String     @default("TODO")
  projectId    String?
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assigneeId String?
  assignee   User?         @relation(fields: [assigneeId], references: [id])
  assignees  User[]        @relation("TaskAssignees")
  documents    Document[]
  comments     TaskComment[]
  subChapterId String?
  subChapter   SubChapter?   @relation(fields: [subChapterId], references: [id], onDelete: Cascade)
  
  // 5W2H extra fields
  why                  String?
  where                String?
  how                  String?
  howMuch              Float?
  
  // Temporal control fields
  dataInicioProgramada  DateTime?
  dataInicioReal        DateTime?
  dataPrevistaFinalizar DateTime?
  dataRealFinalizada    DateTime?
  
  // Progress tracking
  porcentagemExecucao   Int        @default(0)
  
  // Blocked and Urgency tracking
  blockedAt             DateTime?
  blockedReason         String?
  isUrgent              Boolean    @default(false)
  
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Document {
  id             String   @id @default(uuid())
  filename       String
  originalName   String
  isConfidential Boolean  @default(false)
  taskId         String
  task           Task     @relation(fields: [taskId], references: [id])
  createdAt      DateTime @default(now())
}


model TaskComment {
  id            String   @id @default(uuid())
  text          String
  createdAt     DateTime @default(now())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  taskId        String
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  filename      String?
  originalName  String?
}


model SubChapter {
  id        String   @id @default(uuid())
  title     String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress String?
  createdAt DateTime @default(now())
}
